# Google Maps API Key (Required for map functionality)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Site URL (Optional - for canonical URLs, og:image, etc. Default: https://airesderio.com)
# PUBLIC_SITE_URL=https://airesderio.com

# Database (Required for contact form and PDF access)
# PostgreSQL connection string, e.g. DreamHost or local:
# postgresql://user:password@host:5432/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/airesderio

# SMTP (Required for contact form email notifications)
# DreamHost example:
SMTP_HOST=mail.airesderio.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@airesderio.com
SMTP_PASS=your_smtp_password

# Contact Form Email Configuration
CONTACT_FORM_RECIPIENT=info@airesderio.com
CONTACT_FORM_FROM=noreply@airesderio.com

# Admin (for /admin/contactos)
# Comma-separated list of admin emails
ADMIN_EMAILS=admin@airesderio.com
# Shared password for all admins
ADMIN_PASSWORD=change_me
# Secret for signing session cookies (generate with: openssl rand -hex 32)
ADMIN_SESSION_SECRET=your_random_32_char_secret_here

# Server Configuration (Optional - for Node.js deployment)
PORT=3000
HOST=0.0.0.0
