# Google Maps API Key (Required for map functionality)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Site URL (Optional - for canonical URLs, og:image, etc. Default: https://habitat-prime.com.ar)
# PUBLIC_SITE_URL=https://habitat-prime.com.ar

# Resend API Configuration (Required for contact form)
RESEND_API_KEY=re_your_resend_api_key_here

# Contact Form Email Configuration
# IMPORTANT: When using test domain (onboarding@resend.dev), 
# CONTACT_FORM_RECIPIENT MUST be your Resend account email
# (the email you used to sign up for Resend)
# Production (after verifying habitat-prime.com.ar in Resend):
# CONTACT_FORM_RECIPIENT=info@habitat-prime.com.ar
# CONTACT_FORM_FROM=noreply@habitat-prime.com.ar
CONTACT_FORM_RECIPIENT=your-resend-account-email@gmail.com
CONTACT_FORM_FROM=onboarding@resend.dev

# Server Configuration (Optional - for Node.js deployment)
PORT=3000
HOST=0.0.0.0
